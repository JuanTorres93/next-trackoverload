{
  "name": "next-trackoverload-monorepo",
  "private": true,
  "workspaces": [
    "apps/web-and-backend",
    "apps/mobile"
  ],
  "scripts": {
    "install-app": "npm install --w=apps/web-and-backend && npm install --w=apps/mobile",
    "prepare": "husky || true",
    "dev:web": "npm run dev --workspace=apps/web-and-backend",
    "build:web": "npm run build --workspace=apps/web-and-backend",
    "start:web": "npm run start --workspace=apps/web-and-backend",
    "lint:web": "npm run lint --workspace=apps/web-and-backend",
    "test:web": "npm run test --workspace=apps/web-and-backend",
    "test:watch:web": "npm run test:watch --workspace=apps/web-and-backend",
    "start:mobile": "npm run start --workspace=apps/mobile",
    "android:mobile": "npm run android --workspace=apps/mobile",
    "ios:mobile": "npm run ios --workspace=apps/mobile",
    "lint:mobile": "npm run lint --workspace=apps/mobile"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
